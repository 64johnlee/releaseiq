# --- Aurora PostgreSQL (pgvector) ---
# Provision via Vercel dashboard or v0 (Aurora PostgreSQL). Enable pgvector once: CREATE EXTENSION vector;
DATABASE_URL=postgres://user:password@your-aurora-endpoint:5432/releaseiq?sslmode=require

# --- LLM (OpenAI-compatible: Qwen DashScope intl, OpenAI, etc.) ---
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-key
LLM_CHAT_MODEL=qwen-plus
LLM_EMBED_MODEL=text-embedding-v3

# --- GitHub ingestion (optional; raises rate limit) ---
GITHUB_TOKEN=ghp_optional_for_higher_rate_limit
