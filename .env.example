# --- Database ---
# Two supported connection modes (see src/db/client.ts -> selectConnectionMode):
#
# 1. Connection string (local dev, Neon, or any integration that injects a URL).
#    A connection string ALWAYS wins over IAM if both are set.
DATABASE_URL=postgres://user:password@your-aurora-endpoint:5432/releaseiq?sslmode=require
#
# 2. Vercel AWS Marketplace Aurora integration (IAM auth via OIDC — NO password).
#    These are injected automatically by the Vercel integration in deployed
#    environments; do NOT set DATABASE_URL there or it will override IAM mode.
#    Listed here for reference only:
# PGHOST=your-aurora-endpoint.rds.amazonaws.com
# PGPORT=5432
# PGUSER=your_iam_db_user
# PGDATABASE=postgres
# AWS_REGION=ap-southeast-1
# AWS_ROLE_ARN=arn:aws:iam::<account-id>:role/<vercel-oidc-role>
#
# Schema/pgvector: enable the extension once, then apply drizzle/0000_init.sql
# (it begins with `CREATE EXTENSION IF NOT EXISTS vector;`). On the Vercel-managed
# Aurora integration, run it from the dashboard Query editor.

# --- LLM (OpenAI-compatible: Qwen DashScope intl, OpenAI, etc.) ---
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-key
LLM_CHAT_MODEL=qwen-plus
# IMPORTANT: the embed model MUST output 1536-dim vectors to match the DB schema
# (vector(1536), see EMBEDDING_DIM in src/db/schema.ts). Known-good choices:
#   - OpenAI text-embedding-3-small  (1536)
#   - Qwen  text-embedding-v4        (supports dimensions=1536)
# Qwen text-embedding-v3 maxes at 1024 and is INCOMPATIBLE with the default schema.
# To use a different dimension, change EMBEDDING_DIM and regenerate the migration.
LLM_EMBED_MODEL=text-embedding-v4

# --- GitHub ingestion (optional; raises rate limit) ---
GITHUB_TOKEN=ghp_optional_for_higher_rate_limit
